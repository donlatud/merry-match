// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ตาราง Users สำหรับเก็บข้อมูลพื้นฐานและการเข้าสู่ระบบ
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  username      String    @unique
  role          Role      @default(USER)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  // Relationship: 1 User มีได้ 1 Profile
  profile       Profile?
  complaints Complaint[]

  @@map("users") // ตั้งชื่อตารางในฐานข้อมูลเป็นตัวเล็ก
}

// ตาราง Profile สำหรับเก็บข้อมูลส่วนตัวของผู้ใช้ (Dating Profile)
// Map กับฟอร์ม register: full_name←name, birthday←date, gender←sexualIdentity (step2)
model Profile {
  id                String    @id @default(uuid())
  user_id           String    @unique
  full_name         String
  birthday          DateTime
  location          String
  city              String
  gender            String    // ฟอร์ม: sexual_identity (Male, Female, Non-binary, Other)
  sexual_preference String
  racial_preference String
  meeting_interest  String
  bio               String?   @db.Text

  // Relationship: เชื่อมกลับไปที่ User
  user              User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  // Relationship: 1 Profile มีได้หลาย hobbies (แยกตาราง profile_hobbies)
  profileHobbies    ProfileHobby[]
  // Relationship: 1 Profile มีได้หลายรูปภาพ
  images            ProfileImage[]

  // Swipe relations
  requestedSwipes   Swipe[]   @relation("RequestedSwipes")
  receivedSwipes    Swipe[]   @relation("ReceivedSwipes")

  // Subscription (1 Profile มีได้ 1 subscription ที่ active)
  subscription      UserSubscription?

  @@map("profiles")
}

// ตาราง Hobby (master) เก็บรายการ hobby ทั้งระบบ
model Hobby {
  id   Int    @id @default(autoincrement())
  name String @unique

  profileHobbies ProfileHobby[]

  @@map("hobbies")
}

// ตาราง ProfileHobby เชื่อม Profile กับ Hobby (profile_id + hobby_id เป็น primary key)
model ProfileHobby {
  profile_id String
  hobby_id   Int

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  hobby   Hobby   @relation(fields: [hobby_id], references: [id], onDelete: Cascade)

  @@id([profile_id, hobby_id])
  @@map("profile_hobbies")
}

// ตาราง ProfileImage สำหรับเก็บ URL รูปภาพจาก Supabase Storage
model ProfileImage {
  id         Int      @id @default(autoincrement())
  profile_id String
  image_url  String
  order      Int      @default(0) // ลำดับของรูปภาพ

  profile    Profile  @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("profile_images")
}

// กำหนดประเภท Role
enum Role {
  USER
  ADMIN
}

// ตาราง Test สำหรับทดสอบ API (optional)
model Test {
  id   Int    @id @default(autoincrement())
  name String
  @@map("test")
}

// 4. ตาราง Swipes สำหรับระบบ Match (ปัดซ้าย/ปัดขวา)
model Swipe {
  id            Int          @id @default(autoincrement())
  requester_id  String       // คนที่ส่งแรงกด (คนปัด)
  receiver_id   String       // คนที่รับ (คนถูกปัด)
  status        SwipeStatus  // 'LIKE' (ปัดขวา), 'DISLIKE' (ปัดซ้าย)
  created_at    DateTime     @default(now())

  // Relationships
  requester     Profile      @relation("RequestedSwipes", fields: [requester_id], references: [id], onDelete: Cascade)
  receiver      Profile      @relation("ReceivedSwipes", fields: [receiver_id], references: [id], onDelete: Cascade)

  @@map("swipes")
}

// 5. ตาราง Packages ข้อมูลราคาและสิทธิพิเศษ (Master Data)
model Package {
  id                Int                @id @default(autoincrement())
  name              String
  price             Decimal            @db.Decimal(10, 2)
  limit_matching    Int                // จำนวนที่ปัดได้ต่อวัน
  icon_url          String?
  currency          String             @default("THB")
  billing_interval  String             @default("month") // month | year
  features          Json?              // array ข้อความฟีเจอร์สำหรับแสดงบน UI
  is_active         Boolean            @default(true)
  sort_order        Int?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt

  subscriptions     UserSubscription[]
  details           DetailPackage[]

  @@map("packages")
}

// 6. ตาราง UserSubscription เก็บประวัติการซื้อแพ็กเกจของผู้ใช้
model UserSubscription {
  id                   Int                    @id @default(autoincrement())
  profile_id           String                 @unique // 1 โปรไฟล์ มีได้ 1 subscription
  package_id            Int
  status                SubscriptionStatus    @default(PENDING)
  start_date            DateTime              @default(now())
  end_date              DateTime?             // วันหมดอายุ
  gateway               String?               // omise | stripe
  external_charge_id    String?               @unique // จับคู่ webhook
  paid_at               DateTime?             // เวลาชำระสำเร็จจริง

  profile               Profile                @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  package               Package                @relation(fields: [package_id], references: [id])
  transactions          PaymentTransaction[]

  @@map("user_subscriptions")
}

// 7. ตาราง PaymentTransaction เก็บแต่ละครั้งที่ charge (audit + webhook)
model PaymentTransaction {
  id                     Int                       @id @default(autoincrement())
  user_subscription_id   Int
  amount                 Decimal                   @db.Decimal(10, 2)
  currency               String
  gateway                String
  external_charge_id     String?                   @unique // id จาก Omise
  status                 PaymentTransactionStatus  @default(PENDING)
  created_at             DateTime                  @default(now())
  paid_at                DateTime?

  user_subscription      UserSubscription          @relation(fields: [user_subscription_id], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
}

model DetailPackage {
  id         Int      @id @default(autoincrement())

  packageId  Int
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)

  value      String
  position   Int

  createdAt  DateTime @default(now())

  @@unique([packageId, position])
  @@index([packageId])

  @@map("package_details")
}

// Enum สำหรับสถานะ subscription (Merry Package)
enum SubscriptionStatus {
  PENDING   // ยังไม่ชำระเงิน
  ACTIVE    // ชำระสำเร็จ ใช้สิทธิ์ได้
  EXPIRED   // หมดอายุ
  CANCELLED // ยกเลิก
  FAILED    // ชำระไม่สำเร็จ
}

// Enum สำหรับสถานะการชำระเงิน (แต่ละ transaction)
enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// Enum สำหรับสถานะการปัด
enum SwipeStatus {
  LIKE
  DISLIKE
}

enum ComplaintStatus {
  new
  pending
  resolved
  cancelled
}

model Complaint {
  id          String           @id @default(uuid())

  userId      String           @map("user_id")
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  issue       String
  description String

  status      ComplaintStatus  @default(new)
  adminNote   String?          @map("admin_note")

  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  resolvedAt  DateTime?        @map("resolved_at")

  @@map("complaints")
}