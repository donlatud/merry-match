// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model User {
  id         String    @id @default(uuid()) @db.Uuid  // uuid
  email      String    @unique
  username   String    @unique
  role       Role      @default(USER)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  profile    Profile?
  complaints Complaint[]

  @@map("users")
  @@schema("public")
}

model Profile {
  id                String   @id @default(uuid())      // text
  user_id           String   @unique @db.Uuid           // uuid
  full_name         String
  birthday          DateTime
  location          String
  city              String
  gender            String
  sexual_preference String
  racial_preference String
  meeting_interest  String
  bio               String?  @db.Text

  user              User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  profileHobbies    ProfileHobby[]
  images            ProfileImage[]
  requestedSwipes   Swipe[]          @relation("RequestedSwipes")
  receivedSwipes    Swipe[]          @relation("ReceivedSwipes")
  subscription      UserSubscription?

  // Chat relations
  chatRooms1        ChatRoom[]       @relation("ChatRoomProfile1")
  chatRooms2        ChatRoom[]       @relation("ChatRoomProfile2")
  sentMessages      Message[]        @relation("SentMessages")

  // Notification relations
  receivedNotifications Notification[] @relation("NotificationRecipient")
  actorNotifications    Notification[] @relation("NotificationActor")

  @@map("profiles")
  @@schema("public")
}

model Hobby {
  id             Int            @id @default(autoincrement())
  name           String         @unique
  profileHobbies ProfileHobby[]

  @@map("hobbies")
  @@schema("public")
}

model ProfileHobby {
  profile_id String
  hobby_id   Int

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  hobby   Hobby   @relation(fields: [hobby_id], references: [id], onDelete: Cascade)

  @@id([profile_id, hobby_id])
  @@map("profile_hobbies")
  @@schema("public")
}

model ProfileImage {
  id         Int     @id @default(autoincrement())
  profile_id String
  image_url  String
  order      Int     @default(0)

  profile Profile @relation(fields: [profile_id], references: [id], onDelete: Cascade)

  @@map("profile_images")
  @@schema("public")
}

model Test {
  id   Int    @id @default(autoincrement())
  name String

  @@map("test")
  @@schema("public")
}

model Swipe {
  id           Int         @id @default(autoincrement())
  requester_id String      // text
  receiver_id  String      // text
  status       SwipeStatus
  created_at   DateTime    @default(now())

  requester     Profile        @relation("RequestedSwipes", fields: [requester_id], references: [id], onDelete: Cascade)
  receiver      Profile        @relation("ReceivedSwipes", fields: [receiver_id], references: [id], onDelete: Cascade)
  notifications Notification[] @relation("SwipeNotifications")

  @@map("swipes")
  @@schema("public")
}

model Package {
  id               Int      @id @default(autoincrement())
  name             String
  price            Decimal  @db.Decimal(10, 2)
  limit_matching   Int
  icon_url         String?
  currency         String   @default("THB")
  billing_interval String   @default("month")
  features         Json?
  is_active        Boolean  @default(true)
  sort_order       Int?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  subscriptions UserSubscription[]
  details       DetailPackage[]

  @@map("packages")
  @@schema("public")
}

model UserSubscription {
  id                 Int                @id @default(autoincrement())
  profile_id         String             @unique
  package_id         Int
  status             SubscriptionStatus @default(PENDING)
  start_date         DateTime           @default(now())
  end_date           DateTime?
  gateway            String?
  external_charge_id String?            @unique
  paid_at            DateTime?

  profile      Profile              @relation(fields: [profile_id], references: [id], onDelete: Cascade)
  package      Package              @relation(fields: [package_id], references: [id])
  transactions PaymentTransaction[]

  @@map("user_subscriptions")
  @@schema("public")
}

model PaymentTransaction {
  id                   Int                      @id @default(autoincrement())
  user_subscription_id Int
  amount               Decimal                  @db.Decimal(10, 2)
  currency             String
  gateway              String
  external_charge_id   String?                  @unique
  status               PaymentTransactionStatus @default(PENDING)
  created_at           DateTime                 @default(now())
  paid_at              DateTime?

  user_subscription UserSubscription @relation(fields: [user_subscription_id], references: [id], onDelete: Cascade)

  @@map("payment_transactions")
  @@schema("public")
}

model DetailPackage {
  id        Int      @id @default(autoincrement())
  packageId Int
  value     String
  position  Int
  createdAt DateTime @default(now())

  package Package @relation(fields: [packageId], references: [id], onDelete: Cascade)

  @@unique([packageId, position])
  @@index([packageId])
  @@map("package_details")
  @@schema("public")
}

model Complaint {
  id          String          @id @default(uuid())
  userId      String          @map("user_id") @db.Uuid
  issue       String
  description String
  status      ComplaintStatus @default(new)
  adminNote   String?         @map("admin_note")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  resolvedAt  DateTime?       @map("resolved_at")
  cancelledAt DateTime?       @map("cancelled_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("complaints")
  @@schema("public")
}

// ── Chat ──────────────────────────────────────────────────────

model ChatRoom {
  id          String   @id @default(uuid())  // text
  profile1_id String                          // text
  profile2_id String                          // text
  created_at  DateTime @default(now())

  profile1      Profile        @relation("ChatRoomProfile1", fields: [profile1_id], references: [id], onDelete: Cascade)
  profile2      Profile        @relation("ChatRoomProfile2", fields: [profile2_id], references: [id], onDelete: Cascade)
  messages      Message[]
  notifications Notification[] @relation("RoomNotifications")

  @@unique([profile1_id, profile2_id])
  @@map("chat_rooms")
  @@schema("public")
}

model Message {
  id           String   @id @default(uuid())
  room_id      String
  sender_id    String
  content      String?  @db.Text   // ✅ เปลี่ยนเป็น optional
  message_type String   @default("text")
  image_urls   String[] @default([])
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  room   ChatRoom @relation(fields: [room_id], references: [id], onDelete: Cascade)
  sender Profile  @relation("SentMessages", fields: [sender_id], references: [id], onDelete: Cascade)

  @@index([room_id])
  @@index([sender_id])
  @@map("messages")
  @@schema("public")
}

// ── Notifications ─────────────────────────────────────────────

model Notification {
  id           Int              @id @default(autoincrement())
  actor_id     String?
  recipient_id String
  swipe_id     Int?
  room_id      String?
  type         NotificationType
  data         Json?
  created_at   DateTime         @default(now())
  seen_at      DateTime? // ครั้งล่าสุดที่ recipient เปิด dropdown (สำหรับ badge ring)
  read_at      DateTime?

  actor     Profile?  @relation("NotificationActor", fields: [actor_id], references: [id], onDelete: SetNull)
  recipient Profile   @relation("NotificationRecipient", fields: [recipient_id], references: [id], onDelete: Cascade)
  swipe     Swipe?    @relation("SwipeNotifications", fields: [swipe_id], references: [id], onDelete: Cascade)
  room      ChatRoom? @relation("RoomNotifications", fields: [room_id], references: [id], onDelete: Cascade)

  @@unique([recipient_id, type, swipe_id])
  @@unique([recipient_id, type, room_id])
  @@index([recipient_id, created_at])
  @@index([recipient_id, read_at])
  @@map("notifications")
  @@schema("public")
}

// ── Enums ─────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
  @@schema("public")
}

enum SwipeStatus {
  LIKE
  DISLIKE
  @@schema("public")
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  EXPIRED
  CANCELLED
  FAILED
  @@schema("public")
}

enum PaymentTransactionStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  @@schema("public")
}

enum NotificationType {
  LIKED
  MATCHED
  MESSAGE
  @@schema("public")
}

enum ComplaintStatus {
  new
  pending
  resolved
  cancelled
  @@schema("public")
}
